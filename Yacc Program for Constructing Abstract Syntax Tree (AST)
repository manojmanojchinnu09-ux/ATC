%{
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct node {
    char *val;
    struct node *left, *right;
};

struct node* createNode(char* val, struct node* l, struct node* r);
void printTree(struct node* root, int space);

%}

%union {
    char *node;
    struct node *ptr;
}

%token <node> NUM ID
%type <ptr> E
%left '+' '-'
%left '*' '/'

%%
S : E { printf("\nAbstract Syntax Tree (Rotated 90°):\n"); printTree($1, 0); }
  ;

E : E '+' E { $$ = createNode("+", $1, $3); }
  | E '-' E { $$ = createNode("-", $1, $3); }
  | E '*' E { $$ = createNode("*", $1, $3); }
  | E '/' E { $$ = createNode("/", $1, $3); }
  | '(' E ')' { $$ = $2; }
  | NUM { $$ = createNode($1, NULL, NULL); }
  | ID  { $$ = createNode($1, NULL, NULL); }
  ;

%%

struct node* createNode(char* val, struct node* l, struct node* r) {
    struct node* newnode = (struct node*)malloc(sizeof(struct node));
    newnode->val = strdup(val);
    newnode->left = l;
    newnode->right = r;
    return newnode;
}

void printTree(struct node* root, int space) {
    if (root == NULL) return;
    space += 5;
    printTree(root->right, space);
    printf("\n");
    for (int i = 5; i < space; i++) printf(" ");
    printf("%s\n", root->val);
    printTree(root->left, space);
}

int main() {
    printf("Enter expression: ");
    yyparse();
    return 0;
}

void yyerror(char *s) { printf("%s\n", s); }
