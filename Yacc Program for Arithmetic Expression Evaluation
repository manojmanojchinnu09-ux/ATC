%{
#include "y.tab.h"
extern int yylval;
%}

%%
[0-9]+  { yylval = atoi(yytext); return NUMBER; }
[ \t]   { ; }
\n      { return 0; }
.       { return yytext[0]; }
%%

int yywrap() { return 1; }
%{
#include <stdio.h>
#include <stdlib.h>
void yyerror(char *s);
int yylex();
%}

%token NUMBER
%left '+' '-'
%left '*' '/'

%%
arithmetic_expression:
    expression { printf("\nResult: %d\n", $1); return 0; }
    ;

expression:
    expression '+' expression { $$ = $1 + $3; }
    | expression '-' expression { $$ = $1 - $3; }
    | expression '*' expression { $$ = $1 * $3; }
    | expression '/' expression { 
        if($3 == 0) { yyerror("Division by zero!"); exit(1); }
        else $$ = $1 / $3; 
    }
    | '(' expression ')' { $$ = $2; }
    | NUMBER { $$ = $1; }
    ;
%%

void yyerror(char *s) { printf("\nError: %s\n", s); }

int main() {
    printf("Enter an arithmetic expression: ");
    yyparse();
    return 0;
}
